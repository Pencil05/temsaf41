# Google service account credentials. Share the target spreadsheet with GOOGLE_CLIENT_EMAIL as Editor.
GOOGLE_CLIENT_EMAIL="service-account@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nreplace-with-your-private-key\\n-----END PRIVATE KEY-----\\n"
SHEET_ID="1O7UBSJiPKffZVG6isyTrDD1qUpPtvAQ5ZcUiogIzuf4"

# Use a randomly generated value with at least 32 characters.
SESSION_SECRET="replace-with-a-long-random-secret"
ALLOW_MOCK_AUTH="false"

# Required in production for OTP delivery via Gmail.
# Use a Gmail account with 2-Step Verification enabled and create an App Password.
GMAIL_OTP_USER=""
GMAIL_OTP_APP_PASSWORD=""
GMAIL_OTP_FROM=""

# Server-only Gemini API key for the Admin AI assistant.
GEMINI_API_KEY=""

# LINE Official Account Messaging API notifications.
# Use broadcast to notify every OA follower, or push with LINE_OA_TARGET_ID for one user/group/room.
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_OA_DELIVERY_MODE="broadcast"
LINE_OA_TARGET_ID=""
